# secrets.py.sample
# Copy this file to secrets.py and fill in your actual credentials
# NEVER commit secrets.py to git!

secrets = {
    # WiFi credentials (initial boot)
    "ssid": "YOUR_WIFI_SSID_HERE",
    "password": "YOUR_WIFI_PASSWORD_HERE",
    
    # Django backend API settings
    "api_key": "YOUR_API_KEY_HERE",  # X-API-KEY header value
    "device": "pico2w_001",           # Device identifier
    "server_base": "https://your-server.com",  # Django server base URL (no trailing slash)
    
    # Optional: override endpoints (if different from defaults)
    # "events_endpoint": "/booking/api/iot/events/",
    # "config_endpoint": "/booking/api/iot/config/",

    # Diagnostic Mode (Wiring Auto-Detection)
    "DIAGNOSTIC_MODE": False,          # Set to True to enable physical sensor scan mode
}

# Alternative format (for compatibility with some configurations):
# WIFI_SSID = "YOUR_WIFI_SSID_HERE"
# WIFI_PASSWORD = "YOUR_WIFI_PASSWORD_HERE"
# SERVER_URL = "https://your-server.com"
# API_KEY = "YOUR_API_KEY_HERE"
# DEVICE_NAME = "pico2w_001"