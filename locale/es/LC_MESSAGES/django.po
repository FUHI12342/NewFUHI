#: templates/admin/booking/shift_calendar.html:766
msgid "募集を開始する"
msgstr "Iniciar convocatoria"

#: templates/admin/booking/shift_calendar.html:792
msgid "シフト期間がありません。「新規募集」ボタンから作成してください。"
msgstr ""
"No hay períodos de turno. Créelos desde el botón \"Nueva convocatoria\"."

#: templates/admin/booking/shift_calendar.html:800
msgid "休業日設定"
msgstr "Configuración de días de cierre"

#: templates/admin/booking/shift_calendar.html:802
