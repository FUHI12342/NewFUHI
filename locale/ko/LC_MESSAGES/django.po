msgstr "LINE으로 로그인"

msgid "ログアウトしました"
msgstr "로그아웃되었습니다"

msgid "ログインへ戻る"
msgstr "로그인으로 돌아가기"

msgid "ログイン成功"
msgstr "로그인 성공"

