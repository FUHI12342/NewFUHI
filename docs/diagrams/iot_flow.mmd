flowchart TD
    subgraph PicoW["Pico W IoTデバイス"]
        MQ9["MQ-9\nガスセンサー"]
        PIR["PIR\n人感センサー"]
        Light["照度センサー\nフォトレジスタ"]
        DHT["DHT22\n温度 / 湿度"]
        Sound["音センサー"]
    end

    subgraph DjangoAPI["Django APIサーバー"]
        Endpoint["POST /api/iot/events/\nIoTEvent保存"]
        Rules["check_ventilation_rules\n閾値判定"]
        ConfigEP["GET /api/iot/config/\nデバイス設定取得"]
        IRCmd["pending_ir_command\nIRコマンド配信"]
    end

    subgraph VentControl["換気扇自動制御"]
        VentRule["VentilationAutoControl\nON閾値 / OFF閾値 / 連続回数"]
        SwitchBot["SwitchBot API\nturnOn / turnOff"]
        FanState["状態トラッキング\nfan_state / クールダウン"]
        SBEncrypt["SwitchBot認証情報\nFernet暗号化"]
    end

    subgraph Actions["自動アクション"]
        LINEPush["LINE Push\nガスアラーム通知"]
        IRTx["IR送信\nリモコンコード実行"]
    end

    subgraph Monitoring["モニタリング"]
        Dashboard["IoTダッシュボード\nリアルタイム値表示"]
        History["イベント履歴\nトレンドチャート"]
    end

    subgraph PropertyMonitor["不動産IoT監視"]
        Property["物件情報\nProperty"]
        PropDevice["物件デバイス\nPropertyDevice"]
        PropAlert["物件アラート\nガス漏れ / 長期不在 / オフライン"]
    end

    MQ9 -- gas_ppm --> Endpoint
    PIR -- motion_detected --> Endpoint
    Light -- lux_value --> Endpoint
    DHT -- temp_humidity --> Endpoint
    Sound -- sound_level --> Endpoint

    Endpoint -- 閾値判定 --> Rules

    Rules -- "MQ-9超過\n連続カウント" --> VentRule
    VentRule -- "ON/OFF判定" --> SwitchBot
    SBEncrypt -- "復号して認証" --> SwitchBot
    SwitchBot -- "制御結果" --> FanState

    Rules -- "MQ-9危険値\nアラーム" --> LINEPush

    ConfigEP -- "ポーリング間隔\n閾値設定" --> PicoW
    IRCmd -- "IRコマンド" --> PicoW

    Endpoint -- 記録 --> Dashboard
    Endpoint -- 保存 --> History

    SwitchBot -- "Fan ON/OFF\nAC制御" --> FanDevice["SwitchBotデバイス\nファン / エアコン"]

    Endpoint -- "物件紐付け" --> PropDevice
    PropDevice --> PropAlert
    PropAlert -- "通知" --> LINEPush

    classDef sensorStyle fill:#27AE60,stroke:#1E8449,color:#fff
    classDef apiStyle fill:#0C4B33,stroke:#092E20,color:#fff
    classDef actionStyle fill:#E74C3C,stroke:#C0392B,color:#fff
    classDef monitorStyle fill:#3498DB,stroke:#2980B9,color:#fff
    classDef deviceStyle fill:#8E44AD,stroke:#6C3483,color:#fff
    classDef ventStyle fill:#E67E22,stroke:#CA6F1E,color:#fff
    classDef propertyStyle fill:#2C3E50,stroke:#1A252F,color:#fff

    class MQ9,PIR,Light,DHT,Sound sensorStyle
    class Endpoint,Rules,ConfigEP,IRCmd apiStyle
    class LINEPush,IRTx actionStyle
    class Dashboard,History monitorStyle
    class FanDevice deviceStyle
    class VentRule,SwitchBot,FanState,SBEncrypt ventStyle
    class Property,PropDevice,PropAlert propertyStyle
