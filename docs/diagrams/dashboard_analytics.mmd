flowchart TD
    subgraph SalesDash["売上ダッシュボード"]
        KPI["KPIスコアカード\n売上 / 注文数 / 客単価\n前期比 / 目標達成率"]
        MenuEng["メニューエンジニアリング\nStar / Plow / Puzzle / Dog"]
        ABC["ABC分析\nA-B-Cランク分類"]
        Forecast["売上予測\nトレンド分析"]
        Heatmap["売上ヒートマップ\n時間帯 x 曜日"]
        AOV["AOVトラッカー\n平均注文単価"]
    end

    subgraph CustomerAnalytics["顧客分析"]
        Cohort["コホート分析\n月別リテンション率"]
        RFM["RFMセグメンテーション\n最終購入 / 頻度 / 金額"]
        Basket["バスケット分析\n商品ペア相関"]
        NPS["NPSフィードバック\n推奨度 / 料理 / サービス / 雰囲気\n感情分析（自動判定）"]
        CLV["顧客生涯価値\n将来収益予測"]
    end

    subgraph Operations["オペレーション"]
        StaffPerf["スタッフ業績\n売上 / 勤怠 / 評価連動"]
        ShiftSum["シフトサマリー\n日次レポート"]
        LowStock["在庫不足アラート\n閾値通知"]
        AutoOrder["自動発注提案\n補充推奨量算出"]
    end

    subgraph Visitor["来客分析"]
        VForecast["来客予測\n予想トラフィック"]
        VHeatmap["来客ヒートマップ\nピーク時間帯"]
        VTrends["来客トレンド\n週次 / 月次推移"]
    end

    subgraph AI["AI / ML"]
        RecModel["レコメンドモデル\nメニュー提案"]
        InsightEngine["インサイトエンジン\nBusinessInsight自動生成"]
        Training["モデル学習\n定期更新"]
    end

    subgraph ECAnalytics["ECダッシュボード"]
        ECOrders["EC注文管理\n注文一覧 / ステータス"]
        ECShipping["発送管理\n追跡番号 / 配送状況"]
        ECRevenue["EC売上集計\nチャネル別比較"]
    end

    DataSource["データソース\n注文 / 顧客 / IoT / スタッフ / 勤怠"]

    DataSource --> SalesDash
    DataSource --> CustomerAnalytics
    DataSource --> Operations
    DataSource --> Visitor
    DataSource --> AI
    DataSource --> ECAnalytics

    RecModel -- "パーソナライズ提案" --> MenuEng
    Training -- "更新モデル" --> RecModel
    RFM -- "セグメントデータ" --> CLV
    Basket -- "ペアインサイト" --> RecModel
    LowStock -- "トリガー" --> AutoOrder
    NPS -- "顧客満足度" --> InsightEngine
    VForecast -- "予測データ" --> AutoOrder
    InsightEngine -- "アラート" --> StaffPerf

    classDef salesStyle fill:#3498DB,stroke:#2980B9,color:#fff
    classDef custStyle fill:#E74C3C,stroke:#C0392B,color:#fff
    classDef opsStyle fill:#F39C12,stroke:#D68910,color:#fff
    classDef visitorStyle fill:#1ABC9C,stroke:#16A085,color:#fff
    classDef aiStyle fill:#9B59B6,stroke:#7D3C98,color:#fff
    classDef sourceStyle fill:#2C3E50,stroke:#1A252F,color:#fff
    classDef ecStyle fill:#E67E22,stroke:#CA6F1E,color:#fff

    class KPI,MenuEng,ABC,Forecast,Heatmap,AOV salesStyle
    class Cohort,RFM,Basket,NPS,CLV custStyle
    class StaffPerf,ShiftSum,LowStock,AutoOrder opsStyle
    class VForecast,VHeatmap,VTrends visitorStyle
    class RecModel,InsightEngine,Training aiStyle
    class DataSource sourceStyle
    class ECOrders,ECShipping,ECRevenue ecStyle
